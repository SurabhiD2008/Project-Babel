{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd server && npm install && npx prisma generate",
  "outputDirectory": "site",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
