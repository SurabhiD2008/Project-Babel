# Copy this file to `.env` and fill in real values.
# In production these are set as Vercel Environment Variables
# (the Neon integration auto-provides DATABASE_URL / DATABASE_URL_UNPOOLED).

# PostgreSQL (Neon). Pooled URL for the app; unpooled/direct for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Local dev server port
PORT=4600

# Auth — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-string"

# Gate for /api/admin/* and the #/admin page
ADMIN_KEY="change-me"

# Optional: set a key to upgrade the AI endpoints from the offline engine to Claude
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"
